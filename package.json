{
  "name": "buildmypc",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start:frontend": "npm --prefix frontend run dev",
    "start:backend": "npx nodemon --watch backend backend/server.js",
    "start:scraper": "powershell -Command \"cd scraper; .\\venv\\Scripts\\python sync_db.py\"",
    "start:all": "concurrently -c \"cyan,magenta\" -n \"frontend,backend\" \"npm run start:frontend\" \"npm run start:backend\""
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.4",
    "dotenv": "^17.4.2"
  }
}
