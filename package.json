{
  "name": "buildmypc",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "start:backend": "npx nodemon --watch backend backend/server.js",
    "start:scraper": "powershell -Command \"cd scraper; .\\venv\\Scripts\\uvicorn main:app --reload --port 8000\"",
